{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/trunk-sync.sh",
            "statusMessage": "Syncing to trunk"
          }
        ]
      }
    ]
  }
}
